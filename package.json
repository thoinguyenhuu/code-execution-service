{
  "name": "code-execution-service",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "worker": "ts-node src/worker/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npm run prisma:generate && nodemon --watch src --ext ts --exec \"ts-node src/app.ts\"",
    "build": "tsc",
    "db:seed": "npx prisma db seed",
    "prisma:reset": "npx prisma migrate reset --force --skip-seed",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate"
  },
  "prisma": {
    "schema": "./prisma/",
    "seed": "ts-node --transpile-only src/utils/prisma/init.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.73.5",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "prisma": "^6.19.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
