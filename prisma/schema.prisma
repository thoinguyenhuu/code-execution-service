generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  session_id String @id @default(uuid())
  status     String
  language   String
  source_code String

  executions Execution[]   // 👈 không cần name
}

model Execution {
  execution_id             String   @id @default(uuid()) @map("id")
  session_id     String
  status         String
  stdout         String?
  stderr         String?
  source_code_snapshot String
  language_snapshot String
  
  excution_time  DateTime
  started_at DateTime?
  finished_at DateTime?
  excution_time_ms Int?
  session Session @relation(fields: [session_id], references: [session_id])
}